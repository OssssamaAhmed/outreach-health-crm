# Outreach Health CRM — environment variables
#
# Copy this file to .env and fill in real values. Anything not in DEMO mode
# requires DATABASE_URL + JWT_SECRET + the Google OAuth trio at minimum.
#
# Vars beginning with VITE_ are exposed to the browser. Keep server-only
# secrets out of any VITE_-prefixed variable.

# ── Database (required) ──────────────────────────────────────────────────────
# MySQL connection string. Drizzle uses this for migrations + the runtime app.
# Railway, PlanetScale, or local MySQL all work.
DATABASE_URL=mysql://user:password@host:3306/outreach_health

# ── Runtime (recommended) ────────────────────────────────────────────────────
# Most deploy platforms (Railway, Render, Fly) inject NODE_ENV + PORT
# automatically. Set them locally for predictable behavior.
NODE_ENV=development
PORT=3000

# ── Sessions (required) ──────────────────────────────────────────────────────
# Used to sign session cookies. Any random string ≥ 32 chars. Generate with:
#   node -e "console.log(require('crypto').randomBytes(32).toString('hex'))"
JWT_SECRET=replace-me-with-a-32-char-random-secret

# ── Google OAuth (required unless DEMO_MODE=true) ────────────────────────────
# Create a Web Application client at https://console.cloud.google.com/apis/credentials
# Authorized redirect URI must exactly match GOOGLE_REDIRECT_URI below.
GOOGLE_CLIENT_ID=your-client-id.apps.googleusercontent.com
GOOGLE_CLIENT_SECRET=your-client-secret
GOOGLE_REDIRECT_URI=http://localhost:3000/auth/google/callback

# Frontend mirror of the client ID — used to construct the OAuth redirect URL
# from the browser. Must equal GOOGLE_CLIENT_ID. (No corresponding VITE_
# secret: the browser only ever needs the public client ID.)
VITE_GOOGLE_CLIENT_ID=your-client-id.apps.googleusercontent.com

# ── Owner protection (recommended) ───────────────────────────────────────────
# Google "sub" claim of the foundation owner's account. The user matching
# this openId is auto-promoted to super_admin on every login and is immune
# from role-change / deactivation via the API. Find your sub by signing in
# once and reading the value from the users table, OR decode an ID token
# at https://jwt.io. Leaving it empty disables owner protection.
OWNER_OPEN_ID=

# ── Feature flags (optional) ─────────────────────────────────────────────────

# Approval workflow enforcement.
#   false (default) — admins can directly delete/edit major fields.
#   true            — admin destructive/major actions return FORBIDDEN unless
#                     submitted via the approvals.request flow. UI shows the
#                     reason modals + super_admin /pending-approvals page.
# Flip to true after the workflow has been validated end-to-end in staging.
APPROVALS_ENFORCED=false

# Demo mode.
#   false (default) — production OAuth path; real users sign in with Google.
#   true            — Login page swaps to "Sign in as: super-admin / admin /
#                     receptionist" buttons that mint a session directly,
#                     bypassing Google OAuth entirely. Server-side guards
#                     refuse role mutations and seed-user deactivation.
#                     Daily reset cron runs at 03:00 UTC.
# Use only on a separate demo deployment with a separate database.
# VITE_DEMO_MODE must be set to the same value (Vite needs the VITE_-prefixed
# mirror at build time so the frontend can render the role-switcher login,
# demo banner, and read-only badges on the Users page).
DEMO_MODE=false
VITE_DEMO_MODE=false

# Shared secret for the manual demo-reset endpoint
# (POST /__demo/reset). Trigger with:
#   curl -X POST -H "X-Demo-Reset-Secret: <secret>" \
#        https://<demo-host>/__demo/reset
# Leave empty to disable the manual endpoint entirely; the 03:00 UTC cron
# still runs. Only meaningful when DEMO_MODE=true.
DEMO_RESET_SECRET=
